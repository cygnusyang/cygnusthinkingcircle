# 内容制作系统 - LLM 配置
# 复制此文件为 .env 并填入你的配置

# ============================================================
# 方式 1: Anthropic 兼容风格 (Anthropic / DeepSeek)
# ============================================================
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-your-key-here
# LLM_BASE_URL=https://api.deepseek.com/anthropic  # DeepSeek 需指定
# LLM_MODEL=deepseek-v4-pro                         # DeepSeek 需指定

# ============================================================
# 方式 2: OpenAI 兼容风格 (OpenAI / 其他兼容端点)
# ============================================================
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
